{
  "name": "retrieval-kit",
  "version": "0.1.0",
  "description": "A Rust library for local document ingestion, vector search, keyword search, and MCP-style retrieval tool definitions.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepack": "npm run build",
    "pretest": "npm run build:debug",
    "test": "node test/smoke.cjs"
  },
  "napi": {
    "binaryName": "retrieval_kit",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
